library(tidyverse)
# exiftoolrパッケージを使う
# install.packages("exiftoolr")
library(exiftoolr)
# 写真フォルダのパスを指定
src_folder <- "garally"  # 元のフォルダ名に変更
# Exif情報を取得
exif <- exif_read(
list.files(src_folder, full.names = TRUE),
tags = c("FileName", "DateTimeOriginal", "CreateDate")
)
src_folder
getwed()
getwd()
# ステップ1：パッケージのインストール（初回のみ）
install.packages("exiftoolr")
# ステップ2：読み込み
library(exiftoolr)
# ステップ3：ExifTool本体のインストール（初回のみ）
install_exiftool()
# exiftoolrパッケージを使う
# install.packages("exiftoolr")
library(exiftoolr)
# Exif情報を取得
exif <- exif_read(
list.files(src_folder, full.names = TRUE),
tags = c("FileName", "DateTimeOriginal", "CreateDate")
)
# 日付を処理してフォルダ振り分け
exif <- exif %>%
mutate(
date = coalesce(DateTimeOriginal, CreateDate),
date = as.POSIXct(date, format = "%Y:%m:%d %H:%M:%S"),
year = format(date, "%Y"),
month = format(date, "%m"),
dest_folder = file.path("photos", year, month)
)
# フォルダ作成とファイルコピー
exif %>%
filter(!is.na(date)) %>%
rowwise() %>%
mutate(
created = {
dir.create(dest_folder, recursive = TRUE, showWarnings = FALSE)
TRUE
},
copied = file.copy(
file.path(src_folder, FileName),
file.path(dest_folder, FileName)
)
)
# 結果確認
cat("完了した写真数：", sum(exif$copied, na.rm = TRUE), "\n")
cat("日付不明の写真数：", sum(is.na(exif$date)), "\n")
# 結果確認
cat("完了した写真数：", sum(exif$copied, na.rm = TRUE), "\n")
cat("日付不明の写真数：", sum(is.na(exif$date)), "\n")
# 結果確認
list.files("photos", recursive = TRUE)
# install.packages("magick")
library(magick)
install.packages("magick")
library(magick)
files <- list.files("photos", recursive = TRUE, full.names = TRUE,
pattern = "\\.(jpg|jpeg|JPG|JPEG)$")
for (f in files) {
image_read(f) |>
image_resize("1200x") |>
image_write(f, quality = 80)
}
library(tidyverse)
library(exiftoolr)
library(magick)
all_files <- list.files("garally", recursive = TRUE, full.names = TRUE,
pattern = "\\.(jpg|jpeg|JPG|JPEG|png|PNG)$")
# photosフォルダに既にある写真のファイル名
already_done <- basename(list.files("photos", recursive = TRUE,
pattern = "\\.(jpg|jpeg|JPG|JPEG|png|PNG)$"))
# 新しい写真だけ抽出
new_files <- all_files[!basename(all_files) %in% already_done]
if (length(new_files) == 0) {
cat("新しい写真はありません。\n")
} else {
cat("新しい写真：", length(new_files), "枚を処理します。\n")
for (f in new_files) {
cat("圧縮中：", basename(f), "\n")
image_read(f) |>
image_resize("1200x") |>
image_write(f, quality = 80)
}
}
if (length(new_files) > 0) {
exif <- exif_read(new_files,
tags = c("FileName", "DateTimeOriginal", "CreateDate"))
exif <- exif %>%
mutate(
date = coalesce(DateTimeOriginal, CreateDate),
date = as.POSIXct(date, format = "%Y:%m:%d %H:%M:%S"),
year = format(date, "%Y"),
month = format(date, "%m"),
dest_folder = file.path("photos", year, month)
)
# 日付不明の写真を報告
unknown <- exif %>% filter(is.na(date))
if (nrow(unknown) > 0) {
cat("日付不明のためスキップ：", nrow(unknown), "枚\n")
cat(paste("-", unknown$FileName), sep = "\n")
}
# フォルダ作成＆コピー
exif %>%
filter(!is.na(date)) %>%
rowwise() %>%
mutate(
created = {
dir.create(dest_folder, recursive = TRUE, showWarnings = FALSE)
TRUE
},
copied = file.copy(
file.path("garally", FileName),
file.path(dest_folder, FileName)
)
)
cat("完了しました。追加した写真：", sum(!is.na(exif$date)), "枚\n")
}
library(tidyverse)
library(exiftoolr)
library(magick)
all_files <- list.files("gallery", recursive = TRUE, full.names = TRUE,
pattern = "\\.(jpg|jpeg|JPG|JPEG|png|PNG)$")
# photosフォルダに既にある写真のファイル名
already_done <- basename(list.files("photos", recursive = TRUE,
pattern = "\\.(jpg|jpeg|JPG|JPEG|png|PNG)$"))
# 新しい写真だけ抽出
new_files <- all_files[!basename(all_files) %in% already_done]
if (length(new_files) == 0) {
cat("新しい写真はありません。\n")
} else {
cat("新しい写真：", length(new_files), "枚を処理します。\n")
for (f in new_files) {
cat("圧縮中：", basename(f), "\n")
image_read(f) |>
image_resize("1200x") |>
image_write(f, quality = 80)
}
}
if (length(new_files) > 0) {
exif <- exif_read(new_files,
tags = c("FileName", "DateTimeOriginal", "CreateDate"))
exif <- exif %>%
mutate(
date = coalesce(DateTimeOriginal, CreateDate),
date = as.POSIXct(date, format = "%Y:%m:%d %H:%M:%S"),
year = format(date, "%Y"),
month = format(date, "%m"),
dest_folder = file.path("photos", year, month)
)
# 日付不明の写真を報告
unknown <- exif %>% filter(is.na(date))
if (nrow(unknown) > 0) {
cat("日付不明のためスキップ：", nrow(unknown), "枚\n")
cat(paste("-", unknown$FileName), sep = "\n")
}
# フォルダ作成＆コピー
exif %>%
filter(!is.na(date)) %>%
rowwise() %>%
mutate(
created = {
dir.create(dest_folder, recursive = TRUE, showWarnings = FALSE)
TRUE
},
copied = file.copy(
file.path("gallery", FileName),
file.path(dest_folder, FileName)
)
)
cat("完了しました。追加した写真：", sum(!is.na(exif$date)), "枚\n")
}
